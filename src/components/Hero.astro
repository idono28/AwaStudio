---
---

<section class="hero" id="profileArea" aria-label="ヒーローセクション">
  <div class="hero-inner">
    <h1 class="hero-name">AWASTUDIO</h1>
    <p class="hero-role">SOFTWARE DEVELOPER</p>
    <div class="hero-stats">
      <span class="stat"><span class="stat-label">EXP</span> <span class="stat-val">TypeScript / AWS / React</span></span>
    </div>
    <div class="hero-prompt" aria-hidden="true">▲ ナビをクリックして弾を発射 ▲</div>
  </div>

  <!-- Decorative pixel art asteroids -->
  <div class="asteroid a1" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 5 5" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="0" width="3" height="1" fill="#446644"/>
      <rect x="0" y="1" width="5" height="3" fill="#446644"/>
      <rect x="1" y="4" width="3" height="1" fill="#446644"/>
      <rect x="1" y="1" width="1" height="1" fill="#224422"/>
      <rect x="3" y="3" width="1" height="1" fill="#224422"/>
    </svg>
  </div>
  <div class="asteroid a2" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 4 4" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="0" width="2" height="1" fill="#334433"/>
      <rect x="0" y="1" width="4" height="2" fill="#334433"/>
      <rect x="1" y="3" width="2" height="1" fill="#334433"/>
    </svg>
  </div>
  <div class="asteroid a3" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 4 4" xmlns="http://www.w3.org/2000/svg">
      <rect x="0" y="1" width="2" height="2" fill="#223322"/>
      <rect x="1" y="0" width="2" height="4" fill="#223322"/>
      <rect x="2" y="1" width="2" height="2" fill="#223322"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .hero-name {
    font-size: clamp(24px, 5vw, 40px);
    color: var(--color-primary);
    text-shadow:
      0 0 20px var(--color-primary-glow),
      0 0 40px rgba(0, 255, 65, 0.3);
    letter-spacing: 4px;
    line-height: 1.2;
  }

  .hero-role {
    font-size: 9px;
    color: var(--color-accent);
    text-shadow: 0 0 8px rgba(255, 255, 0, 0.5);
    letter-spacing: 2px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
  }

  .stat {
    font-size: 6px;
    color: var(--color-text-muted);
  }

  .stat-label {
    color: var(--color-accent);
    margin-right: 4px;
  }

  .stat-val {
    color: var(--color-primary);
  }

  .hero-prompt {
    font-size: 6px;
    color: var(--color-text-dim);
    margin-top: 8px;
    animation: heroBlink 1s steps(1) infinite;
    letter-spacing: 1px;
  }

  @keyframes heroBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Floating asteroids */
  .asteroid {
    position: absolute;
    image-rendering: pixelated;
    opacity: 0.5;
  }

  .asteroid svg { image-rendering: pixelated; }

  .a1 {
    top: 20%;
    left: 15%;
    animation: drift1 18s linear infinite;
  }
  .a2 {
    top: 30%;
    right: 20%;
    animation: drift2 24s linear infinite;
  }
  .a3 {
    bottom: 30%;
    left: 25%;
    animation: drift3 20s linear infinite;
  }

  @keyframes drift1 {
    0%   { transform: translate(0, 0) rotate(0deg); }
    25%  { transform: translate(15px, 20px) rotate(90deg); }
    50%  { transform: translate(-10px, 30px) rotate(180deg); }
    75%  { transform: translate(-20px, 10px) rotate(270deg); }
    100% { transform: translate(0, 0) rotate(360deg); }
  }
  @keyframes drift2 {
    0%   { transform: translate(0, 0) rotate(0deg); }
    33%  { transform: translate(-20px, 15px) rotate(120deg); }
    66%  { transform: translate(10px, 25px) rotate(240deg); }
    100% { transform: translate(0, 0) rotate(360deg); }
  }
  @keyframes drift3 {
    0%   { transform: translate(0, 0) rotate(0deg); }
    50%  { transform: translate(25px, -15px) rotate(180deg); }
    100% { transform: translate(0, 0) rotate(360deg); }
  }
</style>
