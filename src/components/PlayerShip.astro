---
---

<div class="ship-wrapper" id="shipWrapper" aria-hidden="true">
  <svg
    id="playerShip"
    width="40"
    height="36"
    viewBox="0 0 40 36"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Nose -->
    <rect x="18" y="0" width="4" height="4" fill="#00ff41"/>
    <rect x="16" y="4" width="8" height="4" fill="#00ff41"/>
    <!-- Body -->
    <rect x="12" y="8" width="16" height="4" fill="#00ff41"/>
    <rect x="8" y="12" width="24" height="4" fill="#00ff41"/>
    <rect x="4" y="16" width="32" height="4" fill="#00ff41"/>
    <rect x="0" y="20" width="40" height="4" fill="#00ff41"/>
    <!-- Wings dark -->
    <rect x="4"  y="24" width="8" height="4" fill="#004d18"/>
    <rect x="28" y="24" width="8" height="4" fill="#004d18"/>
    <!-- Thrusters -->
    <rect x="4"  y="28" width="4" height="4" fill="#ffff00" class="thruster"/>
    <rect x="32" y="28" width="4" height="4" fill="#ffff00" class="thruster"/>
    <!-- Cockpit -->
    <rect x="16" y="8"  width="8" height="8" fill="#00aaff"/>
    <rect x="18" y="10" width="4" height="4" fill="#ffffff" opacity="0.8"/>
  </svg>
  <!-- thruster flame -->
  <div class="flame" aria-hidden="true"></div>
</div>

<style>
  .ship-wrapper {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 150;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    transition: left 0.08s linear;
    will-change: left;
  }

  svg {
    display: block;
    image-rendering: pixelated;
    filter: drop-shadow(0 0 6px rgba(0, 255, 65, 0.8));
  }

  .thruster {
    animation: thrusterBlink 0.3s steps(1) infinite;
  }

  @keyframes thrusterBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  .flame {
    width: 8px;
    height: 0px;
    background: linear-gradient(to bottom, #ffff00, #ff8800, transparent);
    animation: flameGrow 0.2s steps(2) infinite alternate;
    margin-top: -2px;
    clip-path: polygon(0% 0%, 100% 0%, 60% 100%, 40% 100%);
  }

  @keyframes flameGrow {
    from { height: 8px; opacity: 1; }
    to   { height: 16px; opacity: 0.6; }
  }
</style>
