---
interface NavItem {
  label: string;
  page: string;
  locked?: boolean;
}

const navItems: NavItem[] = [
  { label: '[ ABOUT ]', page: 'about' },
  { label: '[ SKILLS ]', page: 'skills' },
  { label: '[ WORKS ]', page: 'works', locked: true },
  { label: '[ CONTACT ]', page: 'contact' },
];
---

<header class="hud-bar" id="hudBar">
  <div class="hud-logo">// AWASTUDIO</div>

  <nav aria-label="メインナビゲーション">
    <ul class="nav-items" role="list">
      {navItems.map((item) => (
        <li>
          <button
            class={item.locked ? 'nav-item locked' : 'nav-item'}
            data-page={item.page}
            data-locked={item.locked ? 'true' : undefined}
            disabled={item.locked}
            aria-disabled={item.locked ? 'true' : undefined}
            aria-label={item.locked ? `${item.page}（準備中）` : `${item.page}ページを開く`}
            title={item.locked ? 'COMING SOON / 準備中' : undefined}
          >
            {item.label}
            {item.locked && <span class="nav-lock">SOON</span>}
          </button>
        </li>
      ))}
    </ul>
  </nav>

  <div class="hud-right">
    <span class="hud-score" id="scoreDisplay" aria-live="polite">SCORE: <span id="scoreValue">0000</span></span>
  </div>
</header>

<style>
  .hud-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    row-gap: 8px;
    padding: 10px 24px;
    background: rgba(0, 0, 0, 0.9);
    border-bottom: 2px solid var(--color-primary);
    backdrop-filter: blur(0px);
  }

  @media (max-width: 700px) {
    .hud-bar {
      padding: 10px 14px;
    }

    nav[aria-label='メインナビゲーション'] {
      order: 3;
      width: 100%;
    }

    .nav-items {
      justify-content: center;
      flex-wrap: wrap;
      row-gap: 6px;
    }
  }

  .hud-logo {
    font-size: 14px;
    color: var(--color-primary);
    text-shadow: 0 0 10px var(--color-primary-glow);
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .nav-items {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    font-family: var(--font-pixel);
    font-size: 12px;
    color: var(--color-primary);
    background: transparent;
    border: 1px solid transparent;
    padding: 6px 10px;
    cursor: crosshair;
    transition: border-color 0.1s, background 0.1s;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  .nav-item:not(.locked):hover {
    border-color: var(--color-primary);
    background: var(--color-primary-dim);
    color: #fff;
    text-shadow: 0 0 6px var(--color-primary-glow);
  }

  .nav-item.active {
    border-color: var(--color-primary);
    background: var(--color-primary-dim);
    color: #fff;
    box-shadow: inset 0 0 10px rgba(0, 255, 65, 0.25);
  }

  .nav-item:focus-visible {
    outline: 1px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Locked / coming-soon nav item */
  .nav-item.locked {
    color: var(--color-text-dim);
    opacity: 0.55;
    cursor: not-allowed;
    border-color: transparent;
  }

  .nav-lock {
    font-size: 7px;
    color: var(--color-accent);
    opacity: 0.85;
    margin-left: 6px;
    vertical-align: super;
    letter-spacing: 0.5px;
  }

  .hud-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hud-score {
    font-size: 12px;
    color: var(--color-accent);
    text-shadow: 0 0 6px rgba(255, 255, 0, 0.6);
    white-space: nowrap;
  }
</style>
