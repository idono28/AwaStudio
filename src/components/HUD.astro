---
interface NavItem {
  label: string;
  page: string;
}

const navItems: NavItem[] = [
  { label: '[ ABOUT ]', page: 'about' },
  { label: '[ SKILLS ]', page: 'skills' },
  { label: '[ WORKS ]', page: 'works' },
  { label: '[ CONTACT ]', page: 'contact' },
];
---

<header class="hud-bar" id="hudBar">
  <div class="hud-logo">// HIROKI.DEV</div>

  <nav aria-label="メインナビゲーション">
    <ul class="nav-items" role="list">
      {navItems.map((item) => (
        <li>
          <button
            class="nav-item"
            data-page={item.page}
            aria-label={`${item.page}ページを開く`}
          >
            {item.label}
          </button>
        </li>
      ))}
    </ul>
  </nav>

  <div class="hud-right">
    <span class="hud-score" id="scoreDisplay" aria-live="polite">SCORE: <span id="scoreValue">0000</span></span>
  </div>
</header>

<style>
  .hud-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 24px;
    background: rgba(0, 0, 0, 0.9);
    border-bottom: 2px solid var(--color-primary);
    backdrop-filter: blur(0px);
    height: 52px;
  }

  .hud-logo {
    font-size: 9px;
    color: var(--color-primary);
    text-shadow: 0 0 10px var(--color-primary-glow);
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .nav-items {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    font-family: var(--font-pixel);
    font-size: 7px;
    color: var(--color-primary);
    background: transparent;
    border: 1px solid transparent;
    padding: 6px 10px;
    cursor: crosshair;
    transition: border-color 0.1s, background 0.1s;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  .nav-item:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-dim);
    color: #fff;
    text-shadow: 0 0 6px var(--color-primary-glow);
  }

  .nav-item.active {
    border-color: var(--color-primary);
    background: var(--color-primary-dim);
    color: #fff;
    box-shadow: inset 0 0 10px rgba(0, 255, 65, 0.25);
  }

  .nav-item:focus-visible {
    outline: 1px solid var(--color-primary);
    outline-offset: 2px;
  }

  .hud-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hud-score {
    font-size: 7px;
    color: var(--color-accent);
    text-shadow: 0 0 6px rgba(255, 255, 0, 0.6);
    white-space: nowrap;
  }
</style>
