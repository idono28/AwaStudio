<div class="page-panel" id="pagePanel" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="panelTitle">
  <div class="panel-header">
    <h2 class="panel-title" id="panelTitle">-- PAGE --</h2>
    <button class="close-btn" id="closeBtn" aria-label="ページを閉じる">[ × CLOSE ]</button>
  </div>
  <div class="panel-content" id="panelContent">
    <!-- Content injected by JS -->
  </div>
</div>

<style>
  .page-panel {
    position: fixed;
    top: var(--hud-height, 52px);
    left: 0;
    right: 0;
    z-index: 190;
    background: rgba(0, 0, 0, 0.97);
    border-bottom: 3px solid var(--color-primary);
    transform: translateY(-110%);
    transition: transform 0.45s steps(9);
    max-height: calc(100vh - var(--hud-height, 52px));
    overflow-y: auto;
  }

  .page-panel.open {
    transform: translateY(0);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 20px 40px 14px;
    border-bottom: 1px solid var(--color-primary);
    position: sticky;
    top: 0;
    background: rgba(0, 0, 0, 0.98);
    z-index: 5;
  }

  .panel-title {
    font-size: 20px;
    color: var(--color-primary);
    text-shadow: 0 0 10px var(--color-primary-glow);
    letter-spacing: 1px;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .close-btn {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--color-danger);
    background: transparent;
    border: 1px solid var(--color-danger);
    padding: 8px 12px;
    cursor: crosshair;
    transition: background 0.1s, color 0.1s;
    letter-spacing: 0.5px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 700px) {
    .panel-header {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      padding: 16px 18px 12px;
    }

    .panel-title {
      font-size: 16px;
      text-align: left;
    }

    .close-btn {
      align-self: flex-end;
      font-size: 9px;
      padding: 7px 10px;
    }
  }

  .close-btn:hover {
    background: var(--color-danger);
    color: #000;
  }

  .close-btn:focus-visible {
    outline: 1px solid var(--color-danger);
    outline-offset: 2px;
  }

  .panel-content {
    padding: 28px 40px 40px;
  }
</style>
