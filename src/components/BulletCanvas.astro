---
---

<canvas id="bulletCanvas" aria-hidden="true"></canvas>

<style>
  #bulletCanvas {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.getElementById('bulletCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  interface Bullet {
    x: number;
    y: number;
    vx: number;
    vy: number;
    targetX: number;
    targetY: number;
    framesLeft: number;
    page: string;
    navEl: HTMLElement;
    hit: boolean;
  }

  // Flight lasts a fixed number of frames regardless of distance / screen size,
  // so the click-to-open time stays ~constant (~0.3s at 60fps).
  const FLIGHT_FRAMES = 18;

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    life: number;
    color: string;
    size: number;
  }

  const bullets: Bullet[] = [];
  const particles: Particle[] = [];
  const EXPLOSION_COLORS = ['#ffff00', '#ff8800', '#ff3300', '#00ff41', '#ffffff', '#00aaff'];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function spawnExplosion(x: number, y: number) {
    for (let i = 0; i < 20; i++) {
      const angle = (i / 20) * Math.PI * 2;
      const speed = 1.5 + Math.random() * 3.5;
      particles.push({
        x, y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        life: 1.0,
        color: EXPLOSION_COLORS[Math.floor(Math.random() * EXPLOSION_COLORS.length)],
        size: 2 + Math.floor(Math.random() * 5),
      });
    }
  }

  function tick() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Bullets
    for (let i = bullets.length - 1; i >= 0; i--) {
      const b = bullets[i];
      if (b.hit) { bullets.splice(i, 1); continue; }

      b.x += b.vx;
      b.y += b.vy;
      b.framesLeft--;

      // Reached the target after the fixed flight time
      if (b.framesLeft <= 0) {
        b.x = b.targetX;
        b.y = b.targetY;
        spawnExplosion(b.x, b.y);
        b.hit = true;

        // Update score + open panel
        window.dispatchEvent(new CustomEvent('bullet-hit', { detail: { page: b.page, navEl: b.navEl } }));
        continue;
      }

      // Bullet body
      ctx.fillStyle = '#ffff00';
      ctx.fillRect(Math.round(b.x) - 2, Math.round(b.y) - 6, 4, 12);
      // Bullet glow tip
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(Math.round(b.x) - 1, Math.round(b.y) - 7, 2, 3);
      // Bullet trail
      ctx.fillStyle = 'rgba(255,200,0,0.2)';
      ctx.fillRect(Math.round(b.x) - 1, Math.round(b.y) + 4, 2, 10);
    }

    // Particles
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.vx *= 0.88;
      p.vy *= 0.88;
      p.life -= 0.045;
      if (p.life <= 0) { particles.splice(i, 1); continue; }

      ctx.globalAlpha = p.life;
      ctx.fillStyle = p.color;
      ctx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
      ctx.globalAlpha = 1;
    }

    requestAnimationFrame(tick);
  }
  tick();

  // Public API to fire a bullet
  window.addEventListener('fire-bullet', (e: Event) => {
    const { startX, startY, targetX, targetY, page, navEl } = (e as CustomEvent).detail;
    const dx = targetX - startX;
    const dy = targetY - startY;
    bullets.push({
      x: startX, y: startY,
      vx: dx / FLIGHT_FRAMES,
      vy: dy / FLIGHT_FRAMES,
      targetX, targetY,
      framesLeft: FLIGHT_FRAMES,
      page, navEl,
      hit: false,
    });
  });
</script>
